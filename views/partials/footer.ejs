<script>
// Generic live-search: ek search input ko kisi bhi card list se jorne ke liye.
// Usage: <input oninput="liveSearch(this, '.card-class', 'noResultsId')">
// Har card par data-search="..." attribute hona chahiye (chhota text jis par search ho).
function liveSearch(input, cardSelector, noResultsId) {
  const q = input.value.trim().toLowerCase();
  const cards = document.querySelectorAll(cardSelector);
  let visibleCount = 0;
  cards.forEach(function (card) {
    const haystack = (card.getAttribute('data-search') || card.innerText || '').toLowerCase();
    const match = haystack.includes(q);
    card.style.display = match ? '' : 'none';
    if (match) visibleCount++;
  });
  if (noResultsId) {
    const msg = document.getElementById(noResultsId);
    if (msg) msg.style.display = visibleCount === 0 && cards.length > 0 ? '' : 'none';
  }
}
</script>
