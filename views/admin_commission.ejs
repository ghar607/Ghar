<%- include('partials/header', {title: 'Commission'}) %>

<div class="page-head">
  <h2>Commission Settings</h2>
  <a href="/admin/dashboard" class="cart-link">← Dashboard</a>
</div>

<p class="note">Yeh dono commissions har order ke total par alag alag calculate hoti hain, aur shopkeeper ke payout se kaat li jati hain (sirf admin ke access mein hain).</p>

<h3>🏍️ Rider Commission</h3>
<form method="POST" action="/admin/commission/rider" class="form-card">
  <label>Rider Commission Percentage (%)</label>
  <input type="number" step="0.1" min="0" name="riderCommissionPercent" value="<%= riderCommissionPercent %>" required>
  <p class="note">Yeh hissa rider ke delivery kaam ke evaz mein rakha jata hai.</p>
  <button type="submit" class="btn-primary">Rider Commission Update Karein</button>
</form>

<h3>🛡️ Admin Commission</h3>
<form method="POST" action="/admin/commission/admin" class="form-card">
  <label>Admin Commission Percentage (%)</label>
  <input type="number" step="0.1" min="0" name="adminCommissionPercent" value="<%= adminCommissionPercent %>" required>
  <p class="note">Yeh hissa platform (admin) ka apna commission hai.</p>
  <button type="submit" class="btn-primary">Admin Commission Update Karein</button>
</form>

<%- include('partials/footer') %>
